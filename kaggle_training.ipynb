# ── Markdown cell 4 ──
## 3. Train Model — V4

# V4 fitur:
# Peri-LN → training stabil, grad gak spike
# QKV-norm → attention logit stabil
# Scaled embedding → emb signal seimbang
# Pre-LN head → final proyeksi stabil
# Sliding window global→75% layer O(n·w) instead O(n²)
# WSD scheduler → convergence 2x lebih cepet dari cosine
# β2=0.95, grad clip=1.0, emb LR ×3 body
# Dropout 0.2→0.1 decay
# Cosmopedia + quotes + OASST1 = ~75K samples

# ── Code cell 6 ──
import os; os.chdir('/kaggle/working/aitest')

import subprocess

cmd = [
    'python', 'train.py',
    '--data', 'data/train_full.jsonl',
    '--tokenizer', 'tokenizer.json',
    '--epochs', '10',
    '--batch-size', '16',           # T4 16GB → 16 batch per GPU
    '--grad-accum', '4',            # effective 128 (16×4×2 GPU)
    '--lr', '1e-3',
    '--warmup-steps', '200',        # WSD: 5% warmup
    '--dropout', '0.2',             # decays to 0.1 selama training
    '--emb-lr-mult', '3.0',         # embed learning rate ×3 body
    '--amp',
    '--grad-checkpoint',
    '--val-every', '500',           # validasi tiap 500 step
    '--save-every', '1000',
    '--log-every', '10',
]
subprocess.run(cmd)

