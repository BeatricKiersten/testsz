## 2. Train Tokenizer

# ── Code cell 7 ──
import os; os.chdir('/kaggle/working/aitest')
DATA_PATH = 'data/train_full.jsonl'
TOK_PATH = 'tokenizer.json'
if os.path.exists(TOK_PATH):
    print(f'Tokenizer exists: {TOK_PATH}')
    print('Delete file to retrain')
else:
    !python tokenizer.py --data {DATA_PATH} --vocab-size 16384 --save {TOK_PATH}
    print('Tokenizer created')

# ── Markdown cell 7 ──
## 3A. Train From Scratch

# ── Code cell 8 ──
import os; os.chdir('/kaggle/working/aitest')
import subprocess
cmd = [
    'python', 'train.py',
    '--data', 'data/train_full.jsonl',
    '--tokenizer', 'tokenizer.json',
    '--epochs', '10',
    '--batch-size', '16',
    '--grad-accum', '4',
    '--lr', '1e-3',
    '--warmup-steps', '200',
    '--dropout', '0.2',
    '--emb-lr-mult', '3.0',
    '--amp',
    '--grad-checkpoint',
    '--checkpoint-dir', './checkpoints',
    '--log-every', '10',
    '--save-every', '1000',
    '--val-every', '500',
]
subprocess.run(cmd)

# ── Markdown cell 8 ──
## 3B. Resume Training (jalanin kalo ada checkpoint)

# ── Code cell 9 ──
import os; os.chdir('/kaggle/working/aitest')
import subprocess
# Cek checkpoint terbaru
checkpoints = sorted([f for f in os.listdir('checkpoints') if f.endswith('.pt')]) if os.path.isdir('checkpoints') else []
if checkpoints:
    print('Available checkpoints:')
    for c in checkpoints:
        sz = os.path.getsize(f'checkpoints/{c}')/1024**2
        print(f'  {c} ({sz:.1f} MB)')
else:
    print('No checkpoints found — run step 3A first')

