import os
for f in ['data/train_full.jsonl', 'data/cosmopedia.jsonl']:
    if os.path.exists(f):
        n = sum(1 for _ in open(f))
        sz = os.path.getsize(f) / 1024**2
        print(f'{os.path.basename(f)}: {n} lines, {sz:.1f} MB')

